{
  "expo": {
    "name": "SwipeShot: Photo Cleaner",
    "slug": "swipeshot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "swipeshot",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.ustimweb72.swipeshot",
      "buildNumber": "6",
      "supportsTablet": false,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "SwipeShot needs access to your media library to show and delete selected photos and videos.",
        "NSPhotoLibraryAddUsageDescription": "SwipeShot needs access to your media library to save favorite files.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "locales": {
        "uk": "./locales/uk.lproj/InfoPlist.strings",
        "ru": "./locales/ru.lproj/InfoPlist.strings",
        "en": "./locales/en.lproj/InfoPlist.strings",
        "de": "./locales/de.lproj/InfoPlist.strings",
        "fr": "./locales/fr.lproj/InfoPlist.strings"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ustimweb72.swipeshot"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a97d704f-33f6-42af-b0ba-3999bb77381e"
      }
    },
    "owner": "ustimweb72"
  }
}
